{
  "name": "spaghetti-ai",
  "version": "1.0.0",
  "description": "SpaghettiAI — point a webcam at your 3D printer and let a local vision model catch failed prints (spaghetti), read the bed, identify the printer, and alert you.",
  "type": "module",
  "main": "electron/main.cjs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amosroger91/SpaghettiAI.git"
  },
  "keywords": [
    "3d-printing",
    "ollama",
    "vision",
    "llm",
    "octoprint",
    "print-failure",
    "spaghetti-detection",
    "local-ai"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "serve": "node dist/index.js",
    "setup": "node scripts/ensure-ollama.mjs",
    "mcp": "tsx src/mcp/stdio.ts",
    "mcp:serve": "node dist/mcp/stdio.js",
    "app": "npm run build && electron electron/main.cjs",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "docker:build": "docker build -t printjob-llm-webcam-monitor .",
    "docker:up": "docker compose up --build",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:phone": "npm run build && node scripts/phone-smoke.mjs",
    "fetch-fixtures": "tsx test/fetch-fixtures.ts",
    "eval": "tsx test/eval.ts",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.19.2",
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "sharp": "^0.33.4",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.amosroger91.spaghettiai",
    "productName": "SpaghettiAI",
    "files": [
      "dist/**/*",
      "web/**/*",
      "electron/**/*",
      "scripts/ensure-ollama.mjs",
      "config.json",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "scripts/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
